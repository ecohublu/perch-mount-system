Project project_name {
  database_type: 'PostgreSQL'
  Note: 'Perch Mount System DB'
}


Table members {
    id uuid [ pk, unique ]
    gmail email [ not null ]
    username varchar [ not null ]
    first_name varchar [ not null ]
    last_name varchar [ not null ]
    position positions [ not null ]
    super_admin boolean [ not null, default: false ]
    admin boolean [ not null, default: false]
}

Table projects {
    id uuid [ pk, unique ]
    name varchar
}

Table perch_mounts {
    id uuid [ pk, unique ]
    perch_mount_name varchar [ not null ]
    longitude float [ not null ]
    latitude float [ not null ]
    habitat habitats [ not null ]
    project_id uuid  [ ref: > projects.id ]
    claim_by uuid [ ref: > members.id ]
    is_priority boolean
    terminated boolean [ default: false ]
    layer layers
    note text
}

Table sections {
    id uuid [ pk, unique ]
    perch_mount_id uuid [ ref: > perch_mounts.id ]
    mount_type_id uuid [ ref: > mount_types.id ]
    camera_id uuid [ ref: > cameras.id ]
    swapped_date date [ not null ]
    ground_camera boolean [ not null ]
    valid boolean [ default: true ]
    note text
}

Table section_swappers {
    swapper_id uuid [ ref: > members.id ]
    section_id uuid [ ref: > sections.id ]
}

Table media {
    id uuid [ pk, unique ]
    section_id uuid [ ref: > sections.id ]
    medium_time datetime [ not null ]
    created_time datetime [ not null ]
    deleted_time datetime
    status media_status
    empty_checker_id uuid [ ref: > members.id ]
    nas_path varchar
}


Table detected_media_contents {
    medium_id uuid [ ref: - media.id ]
    detected_time datetime [ not null ]
    model varchar
}

Table accidental_media_contents {
    medium_id uuid [ ref: - media.id ]
    empty_checked_time datetime
    empty_checker_id uuid [ ref: > members.id ]
}

Table reviewed_media_contents {
    medium_id uuid [ ref: - media.id ]
    reviewd_time datetime
    reviewer_id uuid [ ref: > members.id ]
    featured_by uuid [ ref: > members.id ]
    event_id uuid [ ref: > events.id ]
    behaviour_id uuid [ ref: > behaviours.id ]
}

Table individuals {
    id uuid [ pk, unique ]
    medium_id uuid  [ ref: > media.id ]
    taxon_order_by_human integer [ ref: > species.taxon_order ]
    prey_status prey_status
    tagging tagging
    note text
}

Table prey_individuals_contents {
    individual_id uuid [ ref: - individuals.id ]
    prey boolean
    prey_name boolean
}

Table tagged_individuals_contents {
    individual_id uuid [ ref: - individuals.id ]
    tagged boolean
    ring_number varchar
    tag_number varchar
}

Table detected_individuals_contents {
    individual_id uuid [ ref: - individuals.id ]
    taxon_order_by_ai integer [ ref: > species.taxon_order ]
    xmin float
    xmax float
    ymin float
    ymax float
}

Table cameras {
    id uuid [ pk, unique ]
    model_name varchar
}

Table events {
    id uuid [ pk, unique ]
    chinese_name varchar
    english_name varchar
}

Table behaviours {
    id uuid [ pk, unique ]
    chinese_name varchar
    english_name varchar
}

Table mount_types {
    id uuid [ pk, unique ]
    chinese_name varchar
}

Table species {
    taxon_order integer [ pk, unique ]
    scientific_name varchar
    english_common_name varchar
    chinese_common_name varchar
    order varchar
    family_name varchar
    family_latin_name varchar
    taiwan_status varchar
    matzu_status varchar
    kinmen_status varchar
    pratas_status varchar
    endemism varchar
    conservation_status varchar
}

Enum media_status {
    undetected
    detected
    reviewed
    accidental_by_ai
    deleted
}

Enum prey_status {
    unchecked
    has_prey
    no_prey
    identified
}

Enum tagging {
    unchecked
    ring
    tagged
    number_assigned
}

Enum habitats {
    natural
    artificial
    solar_panel
}

Enum positions {
    professor
    postdoc
    doctor
    master
    undergrad
    assistant
    part_time
}

Enum layers {
    high
    middle
    low
}