Project project_name {
  database_type: 'PostgreSQL'
  Note: 'Perch Mount System DB'
}

Ref: media.id > individuals.medium_id
Ref: sections.id > media.section_id
Ref: perch_mounts.id > sections.perch_mount_id
Ref: projects.id > perch_mounts.project_id
Ref: members.id > media.reviewer_id
Ref: members.id > section_swappers.swapper_id
Ref: members.id > perch_mounts.claim_by
Ref: members.id > media.featured_by
Ref: members.id > media.empty_checker_id
Ref: sections.id > section_swappers.section_id
Ref: cameras.id > sections.camera_id
Ref: behaviours.id > individuals.behaviour_id
Ref: events.id > media.event_id
Ref: mount_types.id > sections.mount_type_id
Ref: species.taxon_order > individuals.taxon_order_by_ai
Ref: species.taxon_order > individuals.taxon_order_by_human

Table members {
    id uuid [ pk, unique ]
    gmail email [ not null ]
    username varchar [ not null ]
    first_name varchar [ not null ]
    last_name varchar [ not null ]
    position positions [ not null ]
    super_admin boolean [ not null, default: false ]
    admin boolean [ not null, default: false]
}

Table projects {
    id uuid [ pk, unique ]
    name varchar
}

Table perch_mounts {
    id uuid [ pk, unique ]
    perch_mount_name varchar [ not null ]
    longitude float [ not null ]
    latitude float [ not null ]
    habitat habitats [ not null ]
    project_id uuid [ not null ]
    claim_by uuid
    layer layers
    is_priority boolean
    terminated boolean [ default: false ]
    note text
}

Table sections {
    id uuid [ pk, unique ]
    perch_mount_id uuid
    mount_type_id uuid
    camera_id uuid
    swapped_date date [ not null ]
    ground_camera boolean [ not null ]
    valid boolean [ default: true ]
    note text
}

Table section_swappers {
    swapper_id uuid
    section_id uuid
}

Table media {
    id uuid [ pk, unique ]
    section_id uuid [ not null ]
    medium_time datetime [ not null ]
    created_time datetime [ not null ]
    empty_checked_time datetime
    detected_time datetime
    reviewd_time datetime
    deleted_time datetime
    status media_status
    empty_checker_id uuid
    reviewer_id uuid
    featured_by uuid
    event_id uuid
    nas_path varchar
}

Table individuals {
    id uuid [ pk, unique ]
    medium_id uuid [ not null ]
    taxon_order_by_ai integer
    taxon_order_by_human integer
    tagged boolean
    prey boolean
    prey_name boolean
    tagged boolean
    ring_number varchar
    tag_number varchar
    behaviour_id uuid
    prey_status prey_status
    xmin float
    xmax float
    ymin float
    ymax float
    note text
}

Table cameras {
    id uuid [ pk, unique ]
    model_name varchar
}

Table events {
    id uuid [ pk, unique ]
    chinese_name varchar
    english_name varchar
}

Table behaviours {
    id uuid [ pk, unique ]
    chinese_name varchar
    english_name varchar
}

Table mount_types {
    id uuid [ pk, unique ]
    chinese_name varchar
}

Table species {
    taxon_order integer [ pk, unique ]
    scientific_name varchar
    english_common_name varchar
    chinese_common_name varchar
    order varchar
    family_name varchar
    family_latin_name varchar
    taiwan_status varchar
    matzu_status varchar
    kinmen_status varchar
    pratas_status varchar
    endemism varchar
    conservation_status varchar
}

Enum media_status {
    undetected
    detected
    reviewed
    accidental_by_ai
    deleted
}

Enum prey_status {
    unchecked
    has_prey
    no_prey
    identified
}

Enum tagging {
    unchecked
    ring
    tagged
    number_assigned
}

Enum habitats {
    natural
    artificial
    solar_panel
}

Enum positions {
    professor
    postdoc
    doctor
    master
    undergrad
    assistant
    part_time
}

Enum layers {
    high
    middle
    low
}